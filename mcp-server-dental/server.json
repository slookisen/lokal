{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.slookisen/finn-tannlege-mcp",
  "description": "Norwegian dental clinic directory MCP: ~6,900 clinics with Helfo-agreement, specialty, emergency-duty, and chain data.",
  "repository": {
    "url": "https://github.com/slookisen/lokal",
    "source": "github",
    "subfolder": "mcp-server-dental"
  },
  "version": "0.1.0",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "finn-tannlege-mcp",
      "version": "0.1.0",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "FINN_TANNLEGE_URL",
          "description": "Override API base URL (default: https://finn-tannlege.com)",
          "required": false
        }
      ]
    }
  ],
  "remotes": [
    {
      "type": "streamable-http",
      "url": "https://finn-tannlege.com/mcp"
    }
  ]
}
