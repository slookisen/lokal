{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.slookisen/lokal-mcp",
  "description": "Find local food in Norway. Search 1,100+ farms, shops, REKO rings and cooperatives across 360+ cities. Returns ranked producers with contact info, trust scores, and vCard links.",
  "repository": {
    "url": "https://github.com/slookisen/lokal",
    "source": "github",
    "subfolder": "mcp-server"
  },
  "version": "0.3.3",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "lokal-mcp",
      "version": "0.3.3",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": []
    }
  ],
  "remotes": [
    {
      "type": "streamable-http",
      "url": "https://rettfrabonden.com/mcp"
    }
  ]
}
